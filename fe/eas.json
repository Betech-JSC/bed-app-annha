{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://annha.betech-digital.com/api",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "app-store": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://annha.betech-digital.com/api",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "APP_BUNDLE_ID": "com.annha.app",
        "APP_PACKAGE": "com.annha.app"
      }
    }
  },
  "submit": {
    "production": {},
    "app-store": {
      "ios": {
      }
    }
  }
}
